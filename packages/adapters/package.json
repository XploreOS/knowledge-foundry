{
  "name": "@knowledge-foundry/adapters",
  "version": "0.3.0",
  "description": "Ingestion and format adapters for Knowledge Foundry: local filesystem, web, markdown, JSON, CSV, PDF.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/XploreOS/knowledge-foundry#readme",
  "bugs": "https://github.com/XploreOS/knowledge-foundry/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XploreOS/knowledge-foundry.git",
    "directory": "packages/adapters"
  },
  "keywords": [
    "rag",
    "ingestion",
    "adapters",
    "corpus",
    "knowledge-base"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
